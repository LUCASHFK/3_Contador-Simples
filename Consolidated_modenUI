}

</style>

</head>

<body>

<h1>⚡ Counter</h1>

<div id="container">

    <div id="number">0</div>

    <div class="buttons">
        <button id="increment">+</button>
        <button id="decrement">−</button>
    </div>

    <div class="footer">
        Modern Counter MVP
    </div>

</div>

<script>

let counter = 0;

const numberDisplay =
document.getElementById("number");

document
.getElementById("increment")
.addEventListener("click", function(){

    counter++;

    numberDisplay.innerHTML = counter;

});

document
.getElementById("decrement")
.addEventListener("click", function(){

    counter--;

    numberDisplay.innerHTML = counter;

});

</script>

</body>
